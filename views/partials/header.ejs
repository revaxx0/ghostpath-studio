<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="GhostPath Studio — Independent horror game studio from Türkiye. Crafting atmospheric, story-driven horror experiences. Coming soon: Signal Zero, Backrooms: Fractured Realities.">
  <meta property="og:title" content="GhostPath Studio — Indie Horror Game Studio">
  <meta property="og:description" content="Don't follow the path, let it find you. Independent horror game studio crafting atmospheric, story-driven nightmares.">
  <meta property="og:image" content="https://ghostpathstudio.vercel.app/images/NEWLOGO.jpg">
  <meta property="og:url" content="https://ghostpathstudio.vercel.app">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="GhostPath Studio — Indie Horror Game Studio">
  <meta name="twitter:description" content="Don't follow the path, let it find you. Independent horror game studio from Türkiye.">
  <meta name="twitter:image" content="https://ghostpathstudio.vercel.app/images/NEWLOGO.jpg">
  <link rel="icon" href="/images/NEWLOGO.jpg" type="image/jpeg">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;700&family=Playfair+Display:wght@600;700;800&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="vignette"></div>
  <div class="stars-canvas" id="starsCanvas"></div>
  <header class="header">
    <nav class="navbar">
      <a href="/" class="logo">
        <span class="logo-image-wrap">
          <img src="/images/NEWLOGO.jpg" alt="GhostPath Studio" class="logo-img">
        </span>
        <span class="logo-text">GhostPath Studio</span>
      </a>
      <ul class="nav-links">
        <li><a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>" data-en="Home" data-tr="Ana Sayfa" data-jp="ホーム" data-ru="Главная">Home</a></li>
        <li><a href="#games" data-en="Games" data-tr="Oyunlar" data-jp="ゲーム" data-ru="Игры">Games</a></li>
        <li><a href="#founders" data-en="Team" data-tr="Ekip" data-jp="チーム" data-ru="Команда">Team</a></li>
        <li><a href="/news" data-en="News" data-tr="Haberler" data-jp="ニュース" data-ru="Новости">News</a></li>
        <li><a href="#about" data-en="About" data-tr="Hakkında" data-jp="について" data-ru="О нас">About</a></li>
        <li><a href="#contact" class="nav-cta" data-en="Contact" data-tr="İletişim" data-jp="お問い合わせ" data-ru="Контакты">Contact</a></li>
      </ul>
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
        <span class="theme-icon-dark">☽</span>
        <span class="theme-icon-light" style="display:none">☀</span>
      </button>
      <button class="lang-toggle" id="langToggle" aria-label="Switch language">
        <span class="lang-en active-lang">EN</span>
        <span class="lang-sep">|</span>
        <span class="lang-tr">TR</span>
        <span class="lang-sep">|</span>
        <span class="lang-jp">JP</span>
        <span class="lang-sep">|</span>
        <span class="lang-ru">RU</span>
      </button>
    </nav>
  </header>
