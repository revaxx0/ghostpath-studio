<%- include('partials/header') %>

<!-- Hero -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="noise-overlay"></div>
  <div class="container">
    <div class="hero-content">
      <span class="hero-badge" data-en="✦ Indie Horror Studio" data-tr="✦ Bağımsız Korku Stüdyosu" data-jp="✦ インディーホラー">✦ Indie Horror Studio</span>
      <h1><span data-en="Don&rsquo;t follow the path" data-tr="Yolu takip etme" data-jp="道を追うな">Don&rsquo;t follow the path</span><br><span class="gradient-text" data-en="let it find you." data-tr="bırak yol seni bulsun." data-jp="道に追われろ。">let it find you.</span></h1>
      <p data-en="We craft atmospheric horror experiences that linger long after you&rsquo;ve looked away." data-tr="Baktıktan sonra bile uzun süre aklınızdan çıkmayacak atmosferik korku deneyimleri yaratıyoruz." data-jp="目をそらした後も長く心に残る、空気のようなホラー体験を創造します。">We craft atmospheric horror experiences that linger long after you&rsquo;ve looked away.</p>
      <div class="hero-actions">
        <a href="#games" class="btn btn-primary" data-en="Our Games" data-tr="Oyunlarımız" data-jp="ゲームを見る">Our Games</a>
        <a href="#founders" class="btn btn-outline" data-en="Our Team" data-tr="Ekibimiz" data-jp="チーム紹介">Our Team</a>
      </div>
    </div>
  </div>
</section>

<!-- Games -->
<section id="games" class="games">
  <div class="container">
    <div class="section-header">
      <span class="section-tag" data-en="Our Projects" data-tr="Projelerimiz" data-jp="プロジェクト">Our Projects</span>
      <h2 data-en="Games" data-tr="Oyunlar" data-jp="ゲーム">Games</h2>
      <p data-en="Every project is a doorway into another world. Enter if you dare." data-tr="Her proje başka bir dünyaya açılan bir kapı. Cesaretin varsa gir." data-jp="どのプロジェクトも異世界への扉。勇気があるなら、どうぞ。">Every project is a doorway into another world. Enter if you dare.</p>
    </div>
    <div class="games-grid">
      <% games.forEach(game => { %>
      <div class="game-card">
        <div class="game-image">
          <img src="<%= game.image %>" alt="<%= game.title %>" loading="lazy">
          <div class="game-overlay">
            <a href="<%= game.trailer %>" class="btn-trailer" target="_blank">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              <span data-en="Watch Trailer" data-tr="Fragmanı İzle" data-jp="予告編を見る">Watch Trailer</span>
            </a>
          </div>
        </div>
        <div class="game-info">
          <span class="game-tag"><%= game.tag %></span>
          <h3><%= game.title %></h3>
          <p class="game-desc-en"><%= game.descEN %></p>
          <p class="game-desc-tr" style="display:none"><%= game.descTR %></p>
          <p class="game-desc-jp" style="display:none"><%= game.descJP %></p>
          <span class="game-status"><%= game.statusEN %></span>
          <span class="game-status-tr" style="display:none"><%= game.statusTR %></span>
          <span class="game-status-jp" style="display:none"><%= game.statusJP %></span>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Founders -->
<section id="founders" class="founders">
  <div class="container">
    <div class="section-header">
      <span class="section-tag" data-en="The Minds Behind It" data-tr="Arkasındaki Zihinler" data-jp="創設者">The Minds Behind It</span>
      <h2 data-en="Founders" data-tr="Kurucular" data-jp="創設者">Founders</h2>
      <p data-en="The two pillars of GhostPath Studio." data-tr="GhostPath Studio'nun iki temel direği." data-jp="GhostPath Studioの二本の柱。">The two pillars of GhostPath Studio.</p>
    </div>
    <div class="founders-grid">
      <div class="founder-card">
        <div class="founder-avatar zetagg"></div>
        <h3>Atakan <span class="founder-nick">"ZeTaGG"</span> Sönmez</h3>
        <div class="founder-roles">
          <span class="role-badge">🎨 Model Designer</span>
          <span class="role-badge">🗺️ Map Designer</span>
        </div>
        <p data-en="The architect of our worlds — crafting every model and map with painstaking detail." data-tr="Dünyalarımızın mimarı — her modeli ve haritayı titizlikle işliyor." data-jp="世界の設計者 — 細部までこだわり抜いたモデルとマップを制作。">The architect of our worlds — crafting every model and map with painstaking detail.</p>
      </div>
      <div class="founder-card">
        <div class="founder-avatar revaxx"></div>
        <h3>Necmi Kağan <span class="founder-nick">"ReVaXX"</span> Sönmez</h3>
        <div class="founder-roles">
          <span class="role-badge role-founder">👑 Founder</span>
          <span class="role-badge">💻 Developer</span>
          <span class="role-badge">📖 Game Writer</span>
        </div>
        <p data-en="The mind behind the code and the stories — bringing nightmares to life." data-tr="Kodların ve hikayelerin arkasındaki zihin — kabusları hayata geçiriyor." data-jp="コードと物語の背後にある精神 — 悪夢を現実に。">The mind behind the code and the stories — bringing nightmares to life.</p>
      </div>
    </div>
  </div>
</section>

<!-- News -->
<section id="news" class="news">
  <div class="container">
    <div class="section-header">
      <span class="section-tag" data-en="Latest" data-tr="Son Haberler" data-jp="最新情報">Latest</span>
      <h2 data-en="News & Updates" data-tr="Haberler & Güncellemeler" data-jp="ニュース＆アップデート">News & Updates</h2>
      <p data-en="Follow the latest from GhostPath Studio." data-tr="GhostPath Studio'dan son gelişmeleri takip edin." data-jp="GhostPath Studioの最新情報をお届けします。">Follow the latest from GhostPath Studio.</p>
    </div>
    <div class="news-scroll">
      <table class="news-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Tag</th>
            <th data-en="Title" data-tr="Başlık" data-jp="タイトル">Title</th>
            <th data-en="Description" data-tr="Açıklama" data-jp="説明">Description</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% news.forEach(item => { %>
          <tr>
            <td class="td-date"><%= item.date %></td>
            <td><span class="news-tag"><%= item.tag %></span></td>
            <td class="td-title" data-en="<%= item.titleEN %>" data-tr="<%= item.titleTR %>" data-jp="<%= item.titleJP %>"><%= item.titleEN %></td>
            <td class="td-desc" data-en="<%= item.descEN %>" data-tr="<%= item.descTR %>" data-jp="<%= item.descJP %>"><%= item.descEN %></td>
            <td><a href="#" class="news-link" data-en="Read →" data-tr="Oku →" data-jp="読む →">Read →</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- About -->
<section id="about" class="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-content">
        <span class="section-tag" data-en="About Us" data-tr="Hakkımızda" data-jp="私たちについて">About Us</span>
        <h2 data-en="Who We Are" data-tr="Biz Kimiz" data-jp="私たちは">Who We Are</h2>
        <div class="about-text-en">
          <p>We're a small indie horror game team from Türkiye, passionate about crafting unsettling and atmospheric experiences. GhostPath Studio focuses on creating stories that blend fear, mystery, and emotion — where every sound and shadow matters.</p>
          <p>Our goal isn't perfection — it's immersion. We experiment, learn, and evolve with every project we make. Feedback and honest criticism are always welcome — that's how we grow.</p>
        </div>
        <div class="about-text-tr" style="display:none">
          <p>Türkiye'den küçük bir bağımsız korku oyunu ekibiyiz. Rahatsız edici ve atmosferik deneyimler yaratmaya tutkuluyuz. GhostPath Studio, korku, gizem ve duyguyu harmanlayan hikayeler oluşturmaya odaklanır — her ses ve her gölgenin önemli olduğu bir dünya.</p>
          <p>Hedefimiz mükemmellik değil — etkileyicilik. Her projemizle deney yapıyor, öğreniyor ve gelişiyoruz. Geri bildirim ve dürüst eleştiri her zaman hoş karşılanır — böyle büyüyoruz.</p>
        </div>
        <div class="about-text-jp" style="display:none">
          <p>私たちはトルコの小さなインディーホラーゲームチームです。不安で幻想的な体験を創り出すことに情熱を注いでいます。GhostPath Studioは、恐怖、謎、感情が融合した物語を紡ぎます — すべての音と影に意味がある世界。</p>
          <p>私たちの目標は完璧さではありません — 没入感です。プロジェクトごとに実験し、学び、進化し続けます。フィードバックと正直な批評はいつでも歓迎します — それが成長の糧です。</p>
        </div>
        <div class="about-values">
          <div class="value-item">
            <span class="value-icon">👁️</span>
            <span data-en="Story-driven horror" data-tr="Hikaye odaklı korku" data-jp="ストーリー重視のホラー">Story-driven horror</span>
          </div>
          <div class="value-item">
            <span class="value-icon">🌫️</span>
            <span data-en="Psychological tension & atmosphere" data-tr="Psikolojik gerilim ve atmosfer" data-jp="心理的緊張と雰囲気">Psychological tension & atmosphere</span>
          </div>
          <div class="value-item">
            <span class="value-icon">📜</span>
            <span data-en="Experimental narrative" data-tr="Deneysel anlatı" data-jp="実験的な物語">Experimental narrative</span>
          </div>
        </div>
      </div>
      <div class="about-stats">
        <div class="stat">
          <span class="stat-number">2</span>
          <span class="stat-label" data-en="Games in Development" data-tr="Geliştirme Aşamasında" data-jp="開発中のゲーム">Games in Development</span>
        </div>
        <div class="stat">
          <span class="stat-number">2024</span>
          <span class="stat-label" data-en="Founded" data-tr="Kuruluş" data-jp="設立">Founded</span>
        </div>
        <div class="stat">
          <span class="stat-number">∞</span>
          <span class="stat-label" data-en="Ideas to Explore" data-tr="Keşfedilecek Fikir" data-jp="探求すべきアイデア">Ideas to Explore</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact" class="contact">
  <div class="container">
    <div class="section-header">
      <span class="section-tag" data-en="Get in Touch" data-tr="İletişim" data-jp="お問い合わせ">Get in Touch</span>
      <h2 data-en="Reach Out" data-tr="Bize Ulaşın" data-jp="お問い合わせ">Reach Out</h2>
      <p data-en="Questions, feedback, or just want to say hi — we&rsquo;d love to hear from you." data-tr="Sorular, geri bildirim veya sadece merhaba demek için — sizden haber almayı çok isteriz." data-jp="ご質問、フィードバック、ご挨拶など — お気軽にお聞かせください。">Questions, feedback, or just want to say hi — we&rsquo;d love to hear from you.</p>
    </div>
    <div class="contact-grid">
      <div class="contact-info">
        <div class="contact-card">
          <span class="contact-icon">📧</span>
          <h4 data-en="Email" data-tr="E-posta" data-jp="メール">Email</h4>
          <a href="mailto:ghostpath61@gmail.com">ghostpath61@gmail.com</a>
        </div>
        <div class="contact-card">
          <span class="contact-icon">💬</span>
          <h4>Discord</h4>
          <a href="https://discord.gg/NqsJZtMaQb" target="_blank">discord.gg/NqsJZtMaQb</a>
        </div>
        <div class="contact-card">
          <span class="contact-icon">📺</span>
          <h4>YouTube</h4>
          <a href="https://www.youtube.com/@GhostPathStudio" target="_blank">@GhostPathStudio</a>
        </div>
        <div class="contact-card">
          <span class="contact-icon">📸</span>
          <h4>Instagram</h4>
          <a href="https://www.instagram.com/ghostpathstudio/" target="_blank">@ghostpathstudio</a>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
