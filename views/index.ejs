<%- include('partials/header') %>

<!-- Hero -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="noise-overlay"></div>
  <div class="container">
    <div class="hero-content">
      <span class="hero-badge" data-en="✦ Indie Horror Studio" data-tr="✦ Bağımsız Korku Stüdyosu">✦ Indie Horror Studio</span>
      <h1><span data-en="Don&rsquo;t follow the path" data-tr="Yolu takip etme">Don&rsquo;t follow the path</span><br><span class="gradient-text" data-en="let it find you." data-tr="bırak yol seni bulsun.">let it find you.</span></h1>
      <p data-en="We craft atmospheric horror experiences that linger long after you&rsquo;ve looked away." data-tr="Baktıktan sonra bile uzun süre aklınızdan çıkmayacak atmosferik korku deneyimleri yaratıyoruz.">We craft atmospheric horror experiences that linger long after you&rsquo;ve looked away.</p>
      <div class="hero-actions">
        <a href="#games" class="btn btn-primary" data-en="Our Games" data-tr="Oyunlarımız">Our Games</a>
        <a href="#founders" class="btn btn-outline" data-en="Our Team" data-tr="Ekibimiz">Our Team</a>
      </div>
    </div>
  </div>
</section>

<!-- Games -->
<section id="games" class="games">
  <div class="container">
    <div class="section-header">
      <span class="section-tag" data-en="Our Projects" data-tr="Projelerimiz">Our Projects</span>
      <h2 data-en="Games" data-tr="Oyunlar">Games</h2>
      <p data-en="Every project is a doorway into another world. Enter if you dare." data-tr="Her proje başka bir dünyaya açılan bir kapı. Cesaretin varsa gir.">Every project is a doorway into another world. Enter if you dare.</p>
    </div>
    <div class="games-grid">
      <% games.forEach(game => { %>
      <div class="game-card">
        <div class="game-image">
          <img src="<%= game.image %>" alt="<%= game.title %>" loading="lazy">
          <div class="game-overlay">
            <a href="<%= game.trailer %>" class="btn-trailer" target="_blank">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              <span data-en="Watch Trailer" data-tr="Fragmanı İzle">Watch Trailer</span>
            </a>
          </div>
        </div>
        <div class="game-info">
          <span class="game-tag"><%= game.tag %></span>
          <h3><%= game.title %></h3>
          <p class="game-desc-en"><%= game.descEN %></p>
          <p class="game-desc-tr" style="display:none"><%= game.descTR %></p>
          <span class="game-status"><%= game.statusEN %></span>
          <span class="game-status-tr" style="display:none"><%= game.statusTR %></span>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Founders -->
<section id="founders" class="founders">
  <div class="container">
    <div class="section-header">
      <span class="section-tag" data-en="The Minds Behind It" data-tr="Arkasındaki Zihinler">The Minds Behind It</span>
      <h2 data-en="Founders" data-tr="Kurucular">Founders</h2>
      <p data-en="The two pillars of GhostPath Studio." data-tr="GhostPath Studio'nun iki temel direği.">The two pillars of GhostPath Studio.</p>
    </div>
    <div class="founders-grid">
      <div class="founder-card">
        <div class="founder-avatar zetagg"></div>
        <h3>Atakan <span class="founder-nick">"ZeTaGG"</span> Sönmez</h3>
        <div class="founder-roles">
          <span class="role-badge">🎨 Model Designer</span>
          <span class="role-badge">🗺️ Map Designer</span>
        </div>
        <p data-en="The architect of our worlds — crafting every model and map with painstaking detail." data-tr="Dünyalarımızın mimarı — her modeli ve haritayı titizlikle işliyor.">The architect of our worlds — crafting every model and map with painstaking detail.</p>
      </div>
      <div class="founder-card">
        <div class="founder-avatar revaxx"></div>
        <h3>Necmi Kağan <span class="founder-nick">"ReVaXX"</span> Sönmez</h3>
        <div class="founder-roles">
          <span class="role-badge role-founder">👑 Founder</span>
          <span class="role-badge">💻 Developer</span>
          <span class="role-badge">📖 Game Writer</span>
        </div>
        <p data-en="The mind behind the code and the stories — bringing nightmares to life." data-tr="Kodların ve hikayelerin arkasındaki zihin — kabusları hayata geçiriyor.">The mind behind the code and the stories — bringing nightmares to life.</p>
      </div>
    </div>
  </div>
</section>

<!-- About -->
<section id="about" class="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-content">
        <span class="section-tag" data-en="About Us" data-tr="Hakkımızda">About Us</span>
        <h2 data-en="Who We Are" data-tr="Biz Kimiz">Who We Are</h2>
        <div class="about-text-en">
          <p>We're a small indie horror game team from Türkiye, passionate about crafting unsettling and atmospheric experiences. GhostPath Studio focuses on creating stories that blend fear, mystery, and emotion — where every sound and shadow matters.</p>
          <p>Our goal isn't perfection — it's immersion. We experiment, learn, and evolve with every project we make. Feedback and honest criticism are always welcome — that's how we grow.</p>
        </div>
        <div class="about-text-tr" style="display:none">
          <p>Türkiye'den küçük bir bağımsız korku oyunu ekibiyiz. Rahatsız edici ve atmosferik deneyimler yaratmaya tutkuluyuz. GhostPath Studio, korku, gizem ve duyguyu harmalayan hikayeler oluşturmaya odaklanır — her ses ve her gölgenin önemli olduğu bir dünya.</p>
          <p>Hedefimiz mükemmellik değil — etkileyicilik. Her projemizle deney yapıyor, öğreniyor ve gelişiyoruz. Geri bildirim ve dürüst eleştiri her zaman hoş karşılanır — böyle büyüyoruz.</p>
        </div>
        <div class="about-values">
          <div class="value-item">
            <span class="value-icon">👁️</span>
            <span data-en="Story-driven horror" data-tr="Hikaye odaklı korku">Story-driven horror</span>
          </div>
          <div class="value-item">
            <span class="value-icon">🌫️</span>
            <span data-en="Psychological tension &amp; atmosphere" data-tr="Psikolojik gerilim ve atmosfer">Psychological tension &amp; atmosphere</span>
          </div>
          <div class="value-item">
            <span class="value-icon">📜</span>
            <span data-en="Experimental narrative" data-tr="Deneysel anlatı">Experimental narrative</span>
          </div>
        </div>
      </div>
      <div class="about-stats">
        <div class="stat">
          <span class="stat-number">2</span>
          <span class="stat-label" data-en="Games in Development" data-tr="Geliştirme Aşamasında">Games in Development</span>
        </div>
        <div class="stat">
          <span class="stat-number">2024</span>
          <span class="stat-label" data-en="Founded" data-tr="Kuruluş">Founded</span>
        </div>
        <div class="stat">
          <span class="stat-number">∞</span>
          <span class="stat-label" data-en="Ideas to Explore" data-tr="Keşfedilecek Fikir">Ideas to Explore</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact" class="contact">
  <div class="container">
    <div class="section-header">
      <span class="section-tag" data-en="Get in Touch" data-tr="İletişim">Get in Touch</span>
      <h2 data-en="Reach Out" data-tr="Bize Ulaşın">Reach Out</h2>
      <p data-en="Questions, feedback, or just want to say hi — we&rsquo;d love to hear from you." data-tr="Sorular, geri bildirim veya sadece merhaba demek için — sizden haber almayı çok isteriz.">Questions, feedback, or just want to say hi — we&rsquo;d love to hear from you.</p>
    </div>
    <div class="contact-grid">
      <div class="contact-info">
        <div class="contact-card">
          <span class="contact-icon">📧</span>
          <h4 data-en="Email" data-tr="E-posta">Email</h4>
          <a href="mailto:ghostpath61@gmail.com">ghostpath61@gmail.com</a>
        </div>
        <div class="contact-card">
          <span class="contact-icon">💬</span>
          <h4>Discord</h4>
          <a href="https://discord.gg/NqsJZtMaQb" target="_blank">discord.gg/NqsJZtMaQb</a>
        </div>
        <div class="contact-card">
          <span class="contact-icon">📺</span>
          <h4>YouTube</h4>
          <a href="https://www.youtube.com/@GhostPathStudio" target="_blank">@GhostPathStudio</a>
        </div>
        <div class="contact-card">
          <span class="contact-icon">📸</span>
          <h4>Instagram</h4>
          <a href="https://www.instagram.com/ghostpathstudio/" target="_blank">@ghostpathstudio</a>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
