<%- include('partials/header') %>

<section class="hero">
  <div class="hero-bg"></div>
  <div class="container">
    <div class="hero-content">
      <span class="hero-badge">Digital Studio Est. 2026</span>
      <h1>We Build <span class="gradient-text">Digital</span> Experiences</h1>
      <p>GhostPath Studio is a digital agency specializing in web design, development, and brand strategy. We turn ideas into impactful digital products.</p>
      <div class="hero-actions">
        <a href="#work" class="btn btn-primary">View Our Work</a>
        <a href="#contact" class="btn btn-outline">Get in Touch</a>
      </div>
    </div>
  </div>
</section>

<section id="services" class="services">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">What We Do</span>
      <h2>Our Services</h2>
      <p>From concept to launch, we provide end-to-end digital services.</p>
    </div>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">🎨</div>
        <h3>Web Design</h3>
        <p>Beautiful, user-centric interfaces that captivate and convert.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">⚡</div>
        <h3>Development</h3>
        <p>Fast, scalable web applications built with modern technologies.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">📱</div>
        <h3>Mobile First</h3>
        <p>Responsive designs that work flawlessly across all devices.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">🎯</div>
        <h3>Brand Strategy</h3>
        <p>Strategic branding that tells your story and builds your audience.</p>
      </div>
    </div>
  </div>
</section>

<section id="work" class="work">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Our Portfolio</span>
      <h2>Featured Work</h2>
      <p>Projects we're proud to have delivered.</p>
    </div>
    <div class="work-grid">
      <div class="work-card">
        <div class="work-image" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"></div>
        <div class="work-info">
          <span class="work-tag">Web App</span>
          <h3>Project Nebula</h3>
          <p>Full-stack SaaS platform</p>
        </div>
      </div>
      <div class="work-card">
        <div class="work-image" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);"></div>
        <div class="work-info">
          <span class="work-tag">E-Commerce</span>
          <h3>ShopWave</h3>
          <p>Modern shopping experience</p>
        </div>
      </div>
      <div class="work-card">
        <div class="work-image" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);"></div>
        <div class="work-info">
          <span class="work-tag">Branding</span>
          <h3>Pulse Identity</h3>
          <p>Complete brand identity</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="about" class="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-content">
        <span class="section-tag">About Us</span>
        <h2>Who We Are</h2>
        <p>We are a team of designers, developers, and strategists passionate about creating digital products that make a difference. Founded in 2026, GhostPath Studio has quickly become a trusted partner for brands looking to establish a powerful online presence.</p>
        <p>Our approach combines creative thinking with technical excellence to deliver solutions that exceed expectations.</p>
        <a href="#contact" class="btn btn-primary">Start a Project</a>
      </div>
      <div class="about-stats">
        <div class="stat">
          <span class="stat-number">50+</span>
          <span class="stat-label">Projects Delivered</span>
        </div>
        <div class="stat">
          <span class="stat-number">30+</span>
          <span class="stat-label">Happy Clients</span>
        </div>
        <div class="stat">
          <span class="stat-number">4.9</span>
          <span class="stat-label">Average Rating</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="contact" class="contact">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Get in Touch</span>
      <h2>Let's Work Together</h2>
      <p>Have a project in mind? We'd love to hear about it.</p>
    </div>
    <form class="contact-form">
      <div class="form-row">
        <input type="text" placeholder="Your Name" required>
        <input type="email" placeholder="Your Email" required>
      </div>
      <input type="text" placeholder="Subject">
      <textarea placeholder="Tell us about your project..." rows="5" required></textarea>
      <button type="submit" class="btn btn-primary">Send Message</button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
